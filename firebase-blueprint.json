{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the delivery platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "store", "delivery"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Store": {
      "title": "Store",
      "description": "A fast-food store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "menu": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "description": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "A food delivery order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "storeId": { "type": "string" },
        "deliveryId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "preparing", "out_for_delivery", "delivered", "cancelled"] },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "customerLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "storeLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "deliveryLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "storeId", "status", "total", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session for an order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["orderId", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/stores/{storeId}": { "schema": "Store", "description": "Store information" },
    "/orders/{orderId}": { "schema": "Order", "description": "Delivery orders" },
    "/chats/{chatId}": { "schema": "Chat", "description": "Chat sessions" },
    "/chats/{chatId}/messages/{messageId}": { "schema": "Message", "description": "Messages within a chat" }
  }
}
